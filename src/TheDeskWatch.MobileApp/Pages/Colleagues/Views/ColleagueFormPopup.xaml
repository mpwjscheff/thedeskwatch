<?xml version="1.0" encoding="UTF-8" ?>
<toolkit:Popup
    x:Class="TheDeskWatch.MobileApp.Pages.Colleagues.Views.ColleagueFormPopup"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    xmlns:vm="clr-namespace:TheDeskWatch.MobileApp.Pages.Colleagues.ViewModels"
    x:DataType="vm:ColleagueFormViewModel"
    CanBeDismissedByTappingOutsideOfPopup="True">

    <Border
        BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceBackgroundLight}, Dark={StaticResource SurfaceBackgroundDark}}"
        StrokeThickness="0"
        StrokeShape="RoundRectangle 16,16,0,0"
        Padding="{StaticResource PopupContentPadding}"
        HorizontalOptions="Fill"
        VerticalOptions="End"
        MinimumWidthRequest="{StaticResource PopupMinimumWidth}">

        <VerticalStackLayout Spacing="{StaticResource PopupContentSpacing}">

            <Label
                Text="Full Name"
                Style="{StaticResource SecondaryText}" />

            <Entry
                Text="{Binding Name}"
                Placeholder="e.g. Jane Smith"
                ReturnType="Done"
                ClearButtonVisibility="WhileEditing" />

            <Label
                Text="Colour"
                Style="{StaticResource SecondaryText}" />

            <CollectionView
                ItemsSource="{Binding AvailableSwatches}"
                SelectionMode="Single"
                SelectedItem="{Binding SelectedSwatch}"
                HeightRequest="{StaticResource SwatchStripHeight}">
                <CollectionView.ItemsLayout>
                    <LinearItemsLayout Orientation="Horizontal" ItemSpacing="{StaticResource SwatchSpacing}" />
                </CollectionView.ItemsLayout>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="vm:ColleagueColorSwatch">
                        <Border
                            StrokeShape="Ellipse"
                            StrokeThickness="0"
                            WidthRequest="{StaticResource SwatchSize}"
                            HeightRequest="{StaticResource SwatchSize}"
                            BackgroundColor="{Binding Color}" />
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Button
                Text="Save"
                Command="{Binding SaveCommand}"
                HorizontalOptions="Fill" />

        </VerticalStackLayout>
    </Border>

</toolkit:Popup>
