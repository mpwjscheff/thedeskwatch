<?xml version="1.0" encoding="UTF-8" ?>
<ContentPage
    x:Class="TheDeskWatch.MobileApp.Pages.Colleagues.Pages.ColleaguesPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:TheDeskWatch.MobileApp.Pages.Colleagues.ViewModels"
    x:DataType="vm:ColleaguesPageViewModel"
    Title="{Binding Title}">

    <ContentPage.ToolbarItems>
        <ToolbarItem
            Order="Primary"
            Priority="0"
            Clicked="OnAddTapped">
            <ToolbarItem.IconImageSource>
                <FontImageSource
                    FontFamily="FontAwesome6Solid"
                    Glyph="&#xf067;"
                    Size="20"
                    Color="{AppThemeBinding Light={StaticResource Magenta}, Dark={StaticResource White}}" />
            </ToolbarItem.IconImageSource>
        </ToolbarItem>
    </ContentPage.ToolbarItems>

    <CollectionView
        ItemsSource="{Binding Colleagues}"
        SelectionMode="Single"
        SelectionChanged="OnColleagueSelected">
        <CollectionView.ItemTemplate>
            <DataTemplate x:DataType="vm:ColleagueListItemViewModel">
                <Label
                    Text="{Binding Name}"
                    Style="{StaticResource PrimaryText}"
                    Padding="{StaticResource ListRowPadding}"
                    VerticalTextAlignment="Center" />
            </DataTemplate>
        </CollectionView.ItemTemplate>
    </CollectionView>

</ContentPage>
