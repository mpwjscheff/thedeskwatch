<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="TheDeskWatch.MobileApp.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:pages="clr-namespace:TheDeskWatch.MobileApp.Pages.Colleagues.Pages"
    Title="TheDeskWatch">

    <TabBar>
        <Tab Title="Colleagues">
            <Tab.Icon>
                <FontImageSource
                    FontFamily="FontAwesome6Solid"
                    Glyph="&#xf0c0;"
                    Size="22"
                    Color="{AppThemeBinding Light={StaticResource Magenta}, Dark={StaticResource White}}" />
            </Tab.Icon>
            <ShellContent
                ContentTemplate="{DataTemplate pages:ColleaguesPage}"
                Route="Colleagues" />
        </Tab>
    </TabBar>

</Shell>
